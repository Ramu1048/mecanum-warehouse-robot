    <!-- West Wall -->
    <model name="wall_west">
      <static>true</static>
      <pose>-10 0 1.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.2 16 3</size></box></geometry>
        </collision>
        <visual name="visual">
